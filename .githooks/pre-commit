#!/usr/bin/env bash
# Auto-generated by ~/.claude/bin/bootstrap-project. Do not edit by hand.
# Regenerate: bootstrap-project --force
# Stacks: rust
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"
CARGO_DIR="."


# ============================================================
# Stack: rust
# Template: pre-commit-rust.sh
# ============================================================
# Installed by ~/.claude/bin/bootstrap-project.
# Lives at .githooks/pre-commit in the target repo.
#
# Gate order (fail fast):
#   1. Staged .rs files in src/ do not add .unwrap()/.expect()
#   2. cargo fmt --all -- --check
#   3. cargo clippy --all-targets --all-features -- -D warnings
#   4. cargo test --all (can be SKIPPED with PRE_COMMIT_SKIP_TESTS=1 for
#      large projects where the full suite is too slow; skip should be rare)
#
# Override: set PRE_COMMIT_SKIP=1 to skip everything (emergency only).

set -euo pipefail

if [[ "${PRE_COMMIT_SKIP:-0}" == "1" ]]; then
  echo "[pre-commit] PRE_COMMIT_SKIP=1 — skipping gate"
  exit 0
fi

# CARGO_DIR is injected by bootstrap-project. Defaults to repo root.
# For Tauri projects, this is set to "src-tauri".
CARGO_DIR="${CARGO_DIR:-.}"
REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

STAGED=$(git diff --cached --name-only --diff-filter=ACMR)
if [[ -z "$STAGED" ]]; then
  exit 0
fi

# --------------------------------------------------------------------------
# Gate 1: .unwrap()/.expect() count must not INCREASE vs HEAD
# --------------------------------------------------------------------------
# Mirrors ~/.claude/hooks/BlockRustPanics.mjs exactly: count occurrences in
# HEAD's version of the file, count in the staged version, block if the
# delta is positive. Refactors that net-zero-shuffle panics are allowed.
# Removals are always allowed. Brand-new files with any panic are blocked.
STAGED_RS=$(echo "$STAGED" | grep -E '\.rs$' | grep -v -E '(^|/)tests?/' | grep -v -E '(^|/)benches/' | grep -v -E '(^|/)examples/' | grep -v -E '(^|/)build\.rs$' | grep -v -E '_tests?\.rs$' || true)

count_panics() {
  local content="$1"
  # Strip lines with escape comments before counting
  local u=$(echo "$content" | grep -v 'allow-unwrap:' | grep -v 'allow-expect:' | grep -c -E '\.unwrap\(\)' || true)
  local e=$(echo "$content" | grep -v 'allow-unwrap:' | grep -v 'allow-expect:' | grep -c -E '\.expect\(' || true)
  echo "$u $e"
}

if [[ -n "$STAGED_RS" ]]; then
  OFFENDERS=""
  while IFS= read -r file; do
    [[ -z "$file" ]] && continue
    # HEAD version (empty if new file)
    BEFORE=$(git show "HEAD:$file" 2>/dev/null || true)
    # Staged version
    AFTER=$(git show ":$file" 2>/dev/null || true)
    [[ -z "$AFTER" ]] && continue

    read BU BE <<< "$(count_panics "$BEFORE")"
    read AU AE <<< "$(count_panics "$AFTER")"

    DU=$((AU - BU))
    DE=$((AE - BE))

    if (( DU > 0 || DE > 0 )); then
      OFFENDERS+="${file}: "
      (( DU > 0 )) && OFFENDERS+="+${DU} .unwrap() "
      (( DE > 0 )) && OFFENDERS+="+${DE} .expect() "
      OFFENDERS+="(was ${BU}+${BE}, now ${AU}+${AE})"$'\n'
    fi
  done <<< "$STAGED_RS"

  if [[ -n "$OFFENDERS" ]]; then
    echo "[pre-commit] FAIL: staged changes ADD .unwrap()/.expect() in production code" >&2
    echo "$OFFENDERS" >&2
    echo "[pre-commit] Rule: ~/.claude/rules/languages/rust.md" >&2
    echo "[pre-commit] Use ? propagation or anyhow::Context. If truly unreachable," >&2
    echo "[pre-commit] append '// allow-unwrap: <reason>' on the same line." >&2
    exit 1
  fi
fi

# --------------------------------------------------------------------------
# Gate 2: rustfmt check
# --------------------------------------------------------------------------
echo "[pre-commit] (cd $CARGO_DIR && cargo fmt --all -- --check)"
(cd "$CARGO_DIR" && cargo fmt --all -- --check)

# --------------------------------------------------------------------------
# Gate 3: clippy (warnings = errors)
# --------------------------------------------------------------------------
echo "[pre-commit] (cd $CARGO_DIR && cargo clippy --all-targets --all-features -- -D warnings)"
(cd "$CARGO_DIR" && cargo clippy --all-targets --all-features -- -D warnings)

# --------------------------------------------------------------------------
# Gate 4: tests
# --------------------------------------------------------------------------
if [[ "${PRE_COMMIT_SKIP_TESTS:-0}" == "1" ]]; then
  echo "[pre-commit] SKIPPED tests (PRE_COMMIT_SKIP_TESTS=1)"
else
  echo "[pre-commit] (cd $CARGO_DIR && cargo test --all)"
  (cd "$CARGO_DIR" && cargo test --all)
fi

echo "[pre-commit] OK"
